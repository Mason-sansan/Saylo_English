# Copy to .env.local (not committed). Restart Vite after changes.

# Set to 1 to load sample session history + last session on Growth (preview summaries).
# VITE_DEMO_SESSIONS=1

# Optional: full WebSocket URL (overrides same-origin /api/realtime via Vite). Use wss://… if the page is HTTPS.
# VITE_VOICE_WS_URL=ws://127.0.0.1:8787/api/realtime
