# Copy to .env:  cp .env.example .env

# ── 豆包 / 火山方舟（对话 + 结束时的 JSON 反馈）────────────────
# 控制台：方舟 → API Key 管理 → 创建；再创建「推理接入点」，复制 Endpoint ID
LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_API_KEY=
# 形如 ep-20250101-xxxxx（以控制台为准）
LLM_MODEL=

# 批改「更自然」专用：在方舟新建更小/更快的推理接入点后填其 Endpoint ID（ep-...）。
# 留空则批改用 LLM_MODEL（与主对话同一条接入点）。
NATURAL_COACH_MODEL=

# 兼容旧配置：只填下面也行（不填 LLM_* 时仍可读 OPENAI_*）
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# CHAT_MODEL=gpt-4o-mini

# ── 听力：录音转文字（OpenAI Whisper；与方舟密钥可分开填）──────
# 只填方舟时，对话能用，听力转写会提示缺密钥，直到你填下面之一：
WHISPER_API_KEY=
WHISPER_BASE_URL=https://api.openai.com/v1
WHISPER_MODEL=whisper-1

# ── 可选：服务端朗读（失败时网页会用浏览器自带英文朗读）────────
TTS_API_KEY=
TTS_BASE_URL=https://api.openai.com/v1
TTS_MODEL=tts-1
TTS_VOICE=alloy

# ── 豆包端到端实时语音（Conversation 实时音频对话）─────────────
REALTIME_ENABLED=1
REALTIME_URL=wss://openspeech.bytedance.com/api/v3/realtime/dialogue
REALTIME_APP_ID=
REALTIME_ACCESS_KEY=
REALTIME_RESOURCE_ID=volc.speech.dialog
REALTIME_APP_KEY=PlgvMymc7f3tQnJ6
# O2.0=1.2.1.1, SC2.0=2.2.0.0
REALTIME_MODEL=1.2.1.1
REALTIME_SPEAKER=zh_female_vv_jupiter_bigtts

PORT=8787

# ── 生产：由本进程托管前端静态文件（Docker / Railway 单容器）────────────────
# SERVE_STATIC=1
# STATIC_DIR=/app/voice-server/dist
# 数据卷（Railway Volume 挂到 /data 时示例）：
# USER_DB_PATH=/data/users.sqlite
# SESSION_FILES_DIR=/data/sessions

# ── 可选：服务端账号 + Growth 持久化（前后端一体部署时推荐）────────────────
# 设为 1 时：注册/登录走 /api/auth/*，分数与上次会话存 SQLite；WebSocket /api/realtime 需要已登录 Cookie。
# 前端构建需同时设置 VITE_USE_SERVER_AUTH=1（见 web/README.md）。
# SERVER_AUTH=0
#
# 随机长字符串（生产必填），用于签名会话 Cookie
# SESSION_SECRET=
#
# HTTPS 反代时设为 1，以便 Cookie 带 Secure
# COOKIE_SECURE=0
#
# 自定义 SQLite 路径（默认 voice-server/data/users.sqlite）
# USER_DB_PATH=
#
# 会话文件目录（默认 voice-server/data/sessions）
# SESSION_FILES_DIR=

# 会话结束时是否阻塞等待「维度 quick report」LLM（默认 0：用规则快速报告，Growth 仍更新；设为 1 恢复旧行为）
# CONVERSATION_QUICK_REPORT_LLM=0

# 复盘「更自然」批改：会话中会按小批调用 LLM（默认每批最多 2 轮）。接入点见上方 NATURAL_COACH_MODEL。
# 小模型若常出现 missing_in_model，可改为 1（每轮单独请求，更稳、略慢）。
# NATURAL_COACH_MAX_BATCH_TURNS=2
# NATURAL_COACH_DEBOUNCE_MS=280
# 每一小批 LLM 的超时（毫秒），默认 45000；请求会用 AbortSignal 真正取消 fetch。
# NATURAL_COACH_TIMEOUT_MS=45000
# finishSession 阶段批改最多再等多久（毫秒），超时则剩余轮次记为 drain_cap，避免 Wrapping up 连卡多轮×timeout。默认 28000。
# NATURAL_COACH_DRAIN_MAX_MS=28000

# ── Conversation 开场场景 ───────────────────────────────────────
# 默认：只用 `data/conversation-scenes.json`（按 level 随机），失败则用代码里 CONVERSATION_SCENES —— 启动快。
# 仅当库完全拿不出场景时，若下面设为 1 且已配置 LLM_API_KEY，才会调用「即时 LLM 生成场景」（常需数十秒）。
# CONVERSATION_SCENARIO_LLM=1
